# Copy to .env and adjust as needed. All settings are prefixed with
# AGENTICOS_ and validated at startup (see src/agenticos/settings.py).

AGENTICOS_OLLAMA_MODEL=qwen2.5:3b-instruct
AGENTICOS_OLLAMA_BASE_URL=http://localhost:11434
AGENTICOS_LLM_TEMPERATURE=0.0
AGENTICOS_LLM_MAX_RETRIES=2
AGENTICOS_LLM_REQUEST_TIMEOUT=30

# AGENTICOS_DB_PATH=data/agenticos.db
# AGENTICOS_DOCS_DIR=docs
# AGENTICOS_VECTOR_DB_DIR=vector_db

# --- RAG retrieval tuning ---
AGENTICOS_RAG_TOP_K=3
AGENTICOS_RAG_CHUNK_SIZE=1000
AGENTICOS_RAG_CHUNK_OVERLAP=150
AGENTICOS_RAG_SEARCH_TYPE=mmr
AGENTICOS_RAG_FETCH_K=10
# AGENTICOS_RAG_SCORE_THRESHOLD=0.5

# --- Conversation memory ---
AGENTICOS_MEMORY_ENABLED=true
AGENTICOS_MEMORY_MAX_TURNS=6
# AGENTICOS_MEMORY_DB_PATH=data/agenticos.db

AGENTICOS_SPECIALIST_CONCURRENCY=true
AGENTICOS_LOG_LEVEL=INFO
AGENTICOS_LOG_JSON=false

# --- API server (Docker/AWS deployment) ---
AGENTICOS_API_HOST=0.0.0.0
AGENTICOS_API_PORT=8000
